# EdLight Academy — server environment variables
# Copy to `.env` for local `vercel dev`, and set the same keys in your Vercel
# Project Settings → Environment Variables for production. NEVER commit real
# secrets. The frontend Firebase config lives in src/index.html (it's public).

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate a fresh pair with:  npx web-push generate-vapid-keys
# The PUBLIC key must ALSO be set on the client as window.EDLIGHT_PUSH_VAPID_KEY
# in src/index.html so browsers can subscribe.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL required by the Web Push spec (mailto: or https:).
VAPID_SUBJECT=mailto:contact@edlightacademy.com

# ─── Firebase Admin (server-side Firestore + token verification) ────────────
# The full service-account JSON, as a single-line string (or base64 of it).
# Firebase console → Project settings → Service accounts → Generate new key.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional explicit project id (otherwise taken from the service account).
FIREBASE_PROJECT_ID=edlight-academy

# ─── Cron protection ────────────────────────────────────────────────────────
# A long random string. Vercel automatically sends it as `Authorization:
# Bearer <CRON_SECRET>` on scheduled invocations of /api/send-reminders, and
# /api/send-push accepts it for privileged (admin) sends. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
