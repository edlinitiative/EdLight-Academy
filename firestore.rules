rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Users collection: users can read/write their own document
    match /users/{userId} {
      // Allow user to read their own document, or admins to read any
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow user to create/update their own document
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      // Allow admins to update any user
      allow update: if isAdmin();
      
      // Prevent deletion (optional - remove this line if you want users to delete their accounts)
      allow delete: if false;
      
      // Progress subcollection: users can read/write their own progress
      match /progress/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Quiz attempts: immutable per-attempt documents (score history)
      match /quizAttempts/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false;
      }
      
      // Notifications subcollection
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Reminders subcollection
      match /reminders/{reminderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Notification preferences
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Web Push subscriptions (one document per device/browser)
      match /pushSubscriptions/{subId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Exam attempts (practice exams): one active draft per exam_id
      match /examAttempts/{examId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Exam results (practice exams): persisted for cross-device access
      match /examResults/{examId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Study plans: personalised SRS-based study schedules
      match /studyPlans/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Global streak data
      match /streaks/{streakId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Gamification: trivia XP, levels, daily challenge, leaderboard opt-in
      match /gamification/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public site-wide stats document (for homepage/about metrics)
    match /siteStats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Weekly XP leaderboard (leaderboards/{weekId}/entries/{uid}).
    // The board is public — entries are opt-in and only contain a chosen
    // display alias, so guests can browse it (web + mobile). A user may only
    // write their OWN entry (document id must equal their uid, and the
    // payload's uid must match). XP is client-reported for this MVP — add a
    // Cloud Function validator later if abuse appears.
    match /leaderboards/{periodId}/entries/{entryId} {
      allow read: if true;

      // XP is client-reported for this MVP, so bound it: a tampered client can't
      // write an absurd value, and an update can never DECREASE the stored total
      // (addWeeklyXp uses increment(+x); updateEntryProfile uses increment(0)).
      // A chosen alias is length-capped. Detecting XP faked WITHIN these bounds
      // still needs a Cloud Function validator — deferred.
      allow create: if request.auth != null
                    && request.auth.uid == entryId
                    && request.resource.data.uid == entryId
                    && request.resource.data.xp is number
                    && request.resource.data.xp >= 0
                    && request.resource.data.xp <= 10000000
                    && (!('displayName' in request.resource.data)
                        || request.resource.data.displayName == null
                        || (request.resource.data.displayName is string
                            && request.resource.data.displayName.size() <= 40));
      allow update: if request.auth != null
                    && request.auth.uid == entryId
                    && request.resource.data.uid == entryId
                    && request.resource.data.xp is number
                    && request.resource.data.xp >= resource.data.xp
                    && request.resource.data.xp <= 10000000
                    && (!('displayName' in request.resource.data)
                        || request.resource.data.displayName == null
                        || (request.resource.data.displayName is string
                            && request.resource.data.displayName.size() <= 40));
      allow delete: if false;
    }

    // Per-game record holders — one public doc with the best score per arcade
    // game ({ games: { gameId: { score, displayName, uid } }, updatedAt }).
    // Written by signed-in players when they beat a record; same client-trust
    // MVP model as entries above.
    match /leaderboards/records {
      allow read: if true;
      // `games` is a map of gameId -> { score, displayName, uid }. Rules can
      // bound the top-level shape but can't verify each score was legitimately
      // earned — that needs a Cloud Function. Keep the MVP client-trust model,
      // just constrain the shape so the doc can't be turned into arbitrary data.
      allow create, update: if request.auth != null
                            && request.resource.data.keys().hasOnly(['games', 'updatedAt'])
                            && request.resource.data.games is map;
      allow delete: if false;
    }
    
    // Courses collection: Public read access, admin write
    match /courses/{courseId} {
      allow read: if true; // Anyone can read courses
      allow write: if isAdmin(); // Only admins can write
    }
    
    // Videos collection: Public read access, admin write
    match /videos/{videoId} {
      allow read: if true; // Anyone can read videos
      allow write: if isAdmin(); // Only admins can write
    }
    
    // Quizzes collection: Public read access, admin write
    match /quizzes/{quizId} {
      allow read: if true; // Anyone can read quizzes
      allow write: if isAdmin(); // Only admins can write
    }

    // Trivia content: Public read (guests play the game), admin write.
    // Categories + questions migrated from static code via the admin editor.
    match /trivia_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /trivia_questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Comments collection: Authenticated users can read/write with restrictions
    match /comments/{commentId} {
      // Anyone authenticated can read comments
      allow read: if request.auth != null;
      
      // Authenticated users can create comments with their own authorId.
      // Bound the free-text fields so UGC can't be used to store huge blobs.
      allow create: if request.auth != null &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['threadKey', 'text', 'authorId', 'authorName', 'created_at']) &&
                       request.resource.data.text is string &&
                       request.resource.data.text.size() <= 2000 &&
                       request.resource.data.authorName is string &&
                       request.resource.data.authorName.size() <= 80;

      // Users can update their own comments (text only), admins can update any
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.authorId || isAdmin()) &&
                       // Ensure they're only updating allowed fields
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updated_at', 'likes', 'replyCount']) &&
                       request.resource.data.text is string &&
                       request.resource.data.text.size() <= 2000;
      
      // Users can delete their own comments, admins can delete any
      allow delete: if request.auth != null && 
                       (request.auth.uid == resource.data.authorId || isAdmin());
      
      // Replies subcollection
      match /replies/{replyId} {
        // Anyone authenticated can read replies
        allow read: if request.auth != null;
        
        // Authenticated users can create replies with their own authorId.
        // Bound the free-text fields (same caps as top-level comments).
        allow create: if request.auth != null &&
                         request.resource.data.authorId == request.auth.uid &&
                         request.resource.data.keys().hasAll(['text', 'authorId', 'authorName', 'created_at']) &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() <= 2000 &&
                         request.resource.data.authorName is string &&
                         request.resource.data.authorName.size() <= 80;

        // Users can update their own replies, admins can update any
        allow update: if request.auth != null &&
                         (request.auth.uid == resource.data.authorId || isAdmin()) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updated_at', 'likes']) &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() <= 2000;
        
        // Users can delete their own replies, admins can delete any
        allow delete: if request.auth != null && 
                         (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }
    
    // Comment reports (UGC moderation): authenticated users file reports for
    // admin review. Reports are write-once and only readable by admins.
    match /commentReports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Example: Quiz attempts - users can only access their own attempts
    // match /quiz_attempts/{attemptId} {
    //   allow read, write: if request.auth != null && 
    //                         request.auth.uid == resource.data.userId;
    //   allow create: if request.auth != null && 
    //                   request.auth.uid == request.resource.data.userId;
    // }
    
    // Rate limit counters — server-side only, never client-accessible
    match /_rateLimits/{doc} {
      allow read, write: if false;
    }

    // Sandra chat transcripts: written only by the API (admin SDK).
    // Admins browse all conversations; a student may read their own.
    match /chatConversations/{convId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // Sandra knowledge base (vector embeddings) — server-side only
    match /sandraKb/{chunkId} {
      allow read, write: if false;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

